# Clerk Authentication
# iPhone via Cloudflare quick tunnel: each run gets a new *.trycloudflare.com host.
# If Clerk blocks the page, add that host under Clerk Dashboard → Domains / allowed origins (dev).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_PLACEHOLDER_CHANGE_ME
CLERK_SECRET_KEY=sk_test_PLACEHOLDER_CHANGE_ME

# Clerk Frontend API
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Database (Prisma)
# Example (Supabase Postgres): postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public

# Concierge (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1_PLACEHOLDER_CHANGE_ME
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
DEFAULT_CHAT_LOCALE=zh-HK

# Concierge voice / TTS. Set to "false" to hide mic + 朗讀 controls.
# Voice-0: browser Web Speech (desktop Chrome, etc.). Voice-1: iPhone / Safari — mic uploads to POST /api/concierge/transcribe (Whisper).
NEXT_PUBLIC_CONCIERGE_VOICE_UI=true
# Required for server STT (iPhone mic). Optional: CONCIERGE_WHISPER_MODEL (default whisper-1), CONCIERGE_TRANSCRIBE_MAX_BYTES
OPENAI_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3001
OPENROUTER_APP_NAME=Aura

# Knowledge Bank (KB-2 embeddings) — defaults to using OPENROUTER_API_KEY if EMBEDDING_API_KEY is omitted
EMBEDDING_API_KEY=
EMBEDDING_MODEL=qwen/qwen3-embedding-4b

# Knowledge Bank (KB-1 ingestion) — RSS/Atom → T3 staging
KB_INGEST_CRON_SECRET=change-me
KB_INGEST_LANGUAGE=zh-HK
KB_INGEST_TIER=T3
KB_INGEST_STATUS=staging
KB_INGEST_MAX_ITEMS_PER_FEED=12
KB_INGEST_FETCH_TIMEOUT_MS=12000
# Optional: override feeds list (JSON array of {name,url,language?,topics?})
# Example:
# KB_INGEST_FEEDS_JSON=[{"name":"香港01｜美容手帳","url":"https://www.hk01.com/channel/443/%E7%BE%8E%E5%AE%B9%E6%89%8B%E5%B8%B3/rss","language":"zh-HK","topics":["香港","美容","護膚","彩妝","趨勢","新聞"]}]
KB_INGEST_FEEDS_JSON=
KB_INGEST_USER_AGENT=AuraKBIngest/1.0 (+http://localhost:3000)

# Knowledge Bank (KB-1 ingestion) — HTML sources (no RSS) → T3 staging
KB_INGEST_HTML_MAX_LINKS_PER_SOURCE=25
KB_INGEST_HTML_MAX_ARTICLES_PER_SOURCE=8
# Optional: override HTML sources list (JSON array of {name,listUrl,language?,topics?,includeUrlRegex?,excludeUrlRegex?})
KB_INGEST_HTML_SOURCES_JSON=

# Concierge — safety/ops
# Rate limiting is enforced server-side across /api/concierge/*
CONCIERGE_RATE_LIMIT_WINDOW_SECONDS=60
CONCIERGE_RATE_LIMIT_MAX=20
CONCIERGE_RATE_LIMIT_USER_MAX=30

# Model timeout (OpenRouter) before graceful fallback (ms)
CONCIERGE_MODEL_TIMEOUT_MS=25000

# Log hashing salt (used to hash IPs for abuse monitoring; do not store raw IP)
CONCIERGE_LOG_HASH_SALT=change-me

# Chat retention cleanup (call internal endpoint with token)
CONCIERGE_RETENTION_DAYS=180
CONCIERGE_RETENTION_SECRET=change-me

# Scheduled jobs (Vercel Cron): when CRON_SECRET is set on the project, Vercel sends
# Authorization: Bearer <CRON_SECRET> on cron invocations. Alternatively call routes with ?token= matching a secret below.
CRON_SECRET=

# Knowledge rollups (KB-3): optional dedicated cron token; KB_INGEST_CRON_SECRET is also accepted
KB_ROLLUP_CRON_SECRET=
# Optional JSON array: [{"topic":"香港美容趨勢","language":"zh-HK","days":14}] — max 12 topics; omit for default single topic
KB_ROLLUP_TOPICS_JSON=
