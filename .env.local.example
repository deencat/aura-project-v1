# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_PLACEHOLDER_CHANGE_ME
CLERK_SECRET_KEY=sk_test_PLACEHOLDER_CHANGE_ME

# Clerk Frontend API
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Database (Prisma)
# Example (Supabase Postgres): postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public

# Concierge (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1_PLACEHOLDER_CHANGE_ME
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
DEFAULT_CHAT_LOCALE=zh-HK
OPENROUTER_SITE_URL=http://localhost:3001
OPENROUTER_APP_NAME=Aura

# Knowledge Bank (KB-2 embeddings) — defaults to using OPENROUTER_API_KEY if EMBEDDING_API_KEY is omitted
EMBEDDING_API_KEY=
EMBEDDING_MODEL=qwen/qwen3-embedding-4b

# Concierge — safety/ops
# Rate limiting is enforced server-side across /api/concierge/*
CONCIERGE_RATE_LIMIT_WINDOW_SECONDS=60
CONCIERGE_RATE_LIMIT_MAX=20
CONCIERGE_RATE_LIMIT_USER_MAX=30

# Log hashing salt (used to hash IPs for abuse monitoring; do not store raw IP)
CONCIERGE_LOG_HASH_SALT=change-me

# Chat retention cleanup (call internal endpoint with token)
CONCIERGE_RETENTION_DAYS=180
CONCIERGE_RETENTION_SECRET=change-me
