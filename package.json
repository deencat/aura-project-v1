{
  "name": "social-media-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "memory-init": "node scripts/memory/memory-system.js",
    "memory-server": "node scripts/memory/memory-api.js",
    "memory-stub": "node scripts/memory/memory-stub.js",
    "memory-example": "node scripts/memory/memory-example.js",
    "memory-remove": "node scripts/memory/remove-latest-memory.js",
    "memory-get-latest": "node scripts/memory/get-latest-memory.js",
    "memory-add": "node scripts/memory/add-memory.js",
    "memory-add-conversation": "node scripts/memory/add-conversation.js",
