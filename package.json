    "optimize-images:verbose": "node scripts/image-processing/generate-formats.js --verbose",
    "optimize-images:force": "node scripts/image-processing/generate-formats.js --force",
    "generate-placeholders": "node scripts/image-processing/generate-placeholders.js",
    "generate-placeholders:force": "node scripts/image-processing/generate-placeholders.js --force",
    "generate-responsive": "node scripts/image-processing/generate-responsive-sizes.js",
    "generate-responsive:force": "node scripts/image-processing/generate-responsive-sizes.js --force",
    "analyze-images": "node scripts/image-processing/analyze-images.js",
    "analyze-images:verbose": "node scripts/image-processing/analyze-images.js --verbose",
    "image-report": "node scripts/image-processing/analyze-images.js --format=json > image-report.json",
    "image-optimize": "npm run optimize-images && npm run generate-placeholders",
    "image-optimize:full": "npm run optimize-images && npm run generate-placeholders && npm run generate-responsive"
  },
