// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL1")  // Used for pooled connections (transaction mode)
  directUrl = env("DIRECT_URL1")    // Used for migrations (session mode)
}

model Service {
  id                Int      @id @default(autoincrement())
  name              String
  slug              String   @unique
  category          String
  price             String
  duration          String
  status            String   @default("Draft")
  short_description String?
  long_description  String?  @db.Text
  benefits          String?  @db.Text
  suitable_for      String?  @db.Text
  contraindications String?  @db.Text
  preparation       String?  @db.Text
  aftercare         String?  @db.Text
  section_images    Json?
  template          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([category])
  @@index([status])
}
