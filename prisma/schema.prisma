generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KnowledgeTier {
  T0
  T1
  T2
  T3
}

enum KnowledgeStatus {
  staging
  active
  archived
}

model KnowledgeDocument {
  id          String          @id @default(cuid())
  tier        KnowledgeTier
  status      KnowledgeStatus @default(staging)
  language    String          // e.g. "zh-HK", "zh-Hant", "zh-Hans", "en"
  sourceUrl   String?
  title       String?
  publishedAt DateTime?
  fetchedAt   DateTime        @default(now())
  hash        String?
  trustScore  Float?
  topics      String[]        @default([])

  // KB-1 governance: human approval audit (optional)
  approvedAt       DateTime?
  approvedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks KnowledgeChunk[]

  @@index([tier, status])
  @@index([language])
  @@index([publishedAt])
  @@index([approvedAt])
}

model KnowledgeChunk {
  id         String           @id @default(cuid())
  documentId String
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  chunkIndex Int
  text       String
  tokenCount Int?

  // Stored as JSON float[] for portability; pgvector can be added later.
  embedding          Json?
  embeddingModel   String?
  embeddingVersion String?

  // If/when we use pgvector, add a `vector` field in a follow-up migration.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, chunkIndex])
  @@index([documentId])
}

model KnowledgeRollup {
  id          String   @id @default(cuid())
  topic       String
  language    String   // keep rollups locale-specific
  periodStart DateTime
  periodEnd   DateTime
  summaryText String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([topic, language])
  @@index([periodStart, periodEnd])
}

model IngestionRun {
  id        String   @id @default(cuid())
  startedAt DateTime @default(now())
  endedAt   DateTime?
  status    String   // "running" | "success" | "failed"
  stats     Json?
  errorLog  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startedAt])
  @@index([status])
}

model ConciergeThread {
  id       String @id @default(cuid())
  userId   String
  locale   String // "zh-HK" | "zh-Hans" | "en" (aligned with concierge UI)
  title    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ConciergeMessage[]

  @@index([userId, locale, updatedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
}

model ConciergeMessage {
  id        String @id @default(cuid())
  threadId  String
  thread    ConciergeThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  role    String // "user" | "assistant"
  content String

  // Optional: persist KB citations for later review
  sources      Json?
  rollupSources Json?

  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}

model RateLimitCounter {
  id       String @id @default(cuid())
  key      String
  windowId Int
  count    Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, windowId])
  @@index([windowId])
  @@index([updatedAt])
}

model ConciergeRequestEvent {
  id        String @id @default(cuid())
  route     String
  method    String
  locale    String?

  ipHash    String
  userId    String?

  statusCode Int
  rateLimited Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([route, createdAt])
  @@index([userId, createdAt])
}

